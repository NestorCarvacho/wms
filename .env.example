# Application
APP_NAME="WMS API"
APP_VERSION="1.0.0"
API_PREFIX="/api/v1"

# Database
DATABASE_URL="sqlite:///./wms.db"

# JWT
SECRET_KEY="your-secret-key-change-in-production-use-python-secrets"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
